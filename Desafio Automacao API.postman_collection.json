	"item": [
		{
			"name": "Criar ADM",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let email = \"admin\" + Math.floor(Math.random() * 10000) + \"@email.com\";\r",
							"pm.environment.set(\"adminEmail\", email);\r",
							"\r",
							"\r",
							"pm.test(\"Status 201 - Usuário criado\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"let response = pm.response.json();\r",
							"pm.environment.set(\"userId\", response._id);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"nome\": \"Admin Teste\",\r\n  \"email\": \"{{adminEmail}}\",\r\n  \"password\": \"123456\",\r\n  \"administrador\": \"true\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "https://serverest.dev/usuarios",
					"protocol": "https",
					"host": [
						"serverest",
						"dev"
					],
					"path": [
